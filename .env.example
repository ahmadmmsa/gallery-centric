# --- Database (used by both the app and the postgres container) ---
POSTGRES_USER=galleryusername
POSTGRES_PASSWORD=gallerypassword
POSTGRES_DB=gallery_centric
DATABASE_URL=postgresql+asyncpg://galleryusername:gallerypassword@gallerydb/gallery_centric

# --- Application (non-secret) ---
BASE_URL=http://localhost:8008
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=500
DEBUG=false
ADMIN_USERNAME=admin

# NOTE: Do NOT set SECRET_KEY or ALTCHA_HMAC_KEY here. They are generated on
# first launch and stored (encrypted) in the database.
# The admin password is generated on first launch and printed to the container
# logs; you will be required to change it on first login.
# SITE_NAME and all SEO/social tags are configured from the admin panel
# (Settings > Site Settings / SEO) and stored in the database; the default
# site name is "Gallery Centric".
